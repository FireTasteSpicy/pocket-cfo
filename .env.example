# Pocket CFO — environment template.
# Copy to `.env` and fill in YOUR values.  `.env` is gitignored — NEVER commit it.
# The Semgrep pre-commit hook will block any commit that contains a real key.

# ── Model backend ───────────────────────────────────────────────────────────
# Default path: Gemini API via Google AI Studio (get a key at aistudio.google.com).
# This is all you need to run the core agents locally.
GEMINI_API_KEY=your-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Alternatively: Vertex AI (needs a GCP project) ──────────────────────────
# Comment out the two lines above and uncomment these to use Vertex instead:
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# ── Calendar (Phase 3 — official Google Calendar MCP server) ────────────────
# The Calendar agent consumes Google's hosted MCP server. These come from an
# OAuth 2.0 client you create in a GCP project (Workspace Developer Preview).
# GOOGLE_CALENDAR_MCP_ENDPOINT=https://calendarmcp.googleapis.com/mcp/v1
# GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
